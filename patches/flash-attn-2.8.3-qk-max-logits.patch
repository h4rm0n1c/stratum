+__forceinline__ __device__ void atomic_max_float(float *addr, float value) {
+    if (!isfinite(value)) { return; }
+    int *addr_as_i = reinterpret_cast<int *>(addr);
+    int old = *addr_as_i;
+    while (value > __int_as_float(old)) {
+        const int assumed = old;
+        old = atomicCAS(addr_as_i, assumed, __float_as_int(value));
+        if (old == assumed) { break; }
+    }
+}
+
+template<typename RowMaxTensor, typename RowTensor>
+__forceinline__ __device__ void record_block_max_logits(float *max_logits, const int head_idx, RowMaxTensor &row_max, RowTensor &row_tensor, const int actual_seqlen_q, const float scale) {
+    if (max_logits == nullptr) { return; }
+    #pragma unroll
+    for (int mi = 0; mi < size(row_max); ++mi) {
+        const int row = get<0>(row_tensor(mi));
+        if (row < actual_seqlen_q) {
+            atomic_max_float(max_logits + head_idx, row_max(mi) * scale);
+        }
+    }
+}
+
